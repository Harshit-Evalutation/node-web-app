<%
  // Compute dynamic sidebar badge counts from locals
  var svcHealthy = typeof services !== 'undefined' ? services.filter(function(s){ return s.status === 'healthy'; }).length : 0;
  var svcTotal   = typeof services !== 'undefined' ? services.length : 0;
  var cntRunning = typeof containers !== 'undefined' ? containers.filter(function(c){ return c.status === 'running'; }).length : 0;
  var incOpen    = typeof incidents !== 'undefined' ? incidents.filter(function(i){ return i.status !== 'resolved'; }).length : 0;
%>

<aside class="sidebar">
  <div class="sidebar-header">
    <div class="sidebar-brand-icon">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" style="width:13px; height:13px;">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
      </svg>
    </div>
    <div>
      <div class="sidebar-brand-text">OpsCenter</div>
      <div class="sidebar-brand-sub">DevOps Platform</div>
    </div>
  </div>

  <nav class="sidebar-nav">
    <div class="sidebar-group">
      <div class="sidebar-group-title">Overview</div>
      <a href="/" class="sidebar-link <%= page === 'dashboard' ? 'active' : '' %>">
        <div class="sidebar-link-content">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2H6a2 2 0 01-2-2v-4zM14 16a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2h-2a2 2 0 01-2-2v-4z" />
          </svg>
          <span>Dashboard</span>
        </div>
      </a>
    </div>

    <div class="sidebar-group">
      <div class="sidebar-group-title">Monitoring</div>
      <a href="/services" class="sidebar-link <%= page === 'services' ? 'active' : '' %>">
        <div class="sidebar-link-content">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
          <span>Services</span>
        </div>
        <% if (svcTotal > 0) { %>
          <span class="sidebar-badge"><%= svcHealthy %>/<%= svcTotal %></span>
        <% } %>
      </a>

      <a href="/containers" class="sidebar-link <%= page === 'containers' ? 'active' : '' %>">
        <div class="sidebar-link-content">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
          <span>Containers</span>
        </div>
        <% if (cntRunning > 0) { %>
          <span class="sidebar-badge"><%= cntRunning %></span>
        <% } %>
      </a>

      <a href="/deployments" class="sidebar-link <%= page === 'deployments' ? 'active' : '' %>">
        <div class="sidebar-link-content">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
          </svg>
          <span>Deployments</span>
        </div>
      </a>
    </div>

    <div class="sidebar-group">
      <div class="sidebar-group-title">Operations</div>
      <a href="/logs" class="sidebar-link <%= page === 'logs' ? 'active' : '' %>">
        <div class="sidebar-link-content">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <span>Log Viewer</span>
        </div>
      </a>

      <a href="/incidents" class="sidebar-link <%= page === 'incidents' ? 'active' : '' %>">
        <div class="sidebar-link-content">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
          <span>Incidents</span>
        </div>
        <% if (incOpen > 0) { %>
          <span class="sidebar-badge danger"><%= incOpen %></span>
        <% } %>
      </a>
    </div>

    <div class="sidebar-group">
      <div class="sidebar-group-title">Infrastructure</div>
      <a href="/environments" class="sidebar-link <%= page === 'environments' ? 'active' : '' %>">
        <div class="sidebar-link-content">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
          </svg>
          <span>Environments</span>
        </div>
      </a>

      <a href="/cicd" class="sidebar-link <%= page === 'cicd' ? 'active' : '' %>">
        <div class="sidebar-link-content">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
          <span>CI/CD Pipeline</span>
        </div>
      </a>
    </div>
  </nav>

  <!-- Team Activity -->
  <div class="sidebar-activity">
    <div class="sidebar-activity-title">Team Activity</div>
    <div class="activity-feed">
      <% activityList.forEach(function(act) { %>
        <div class="activity-item">
          <strong><%= act.user %></strong> <%= act.action %>
          <div style="color: var(--text-secondary); font-size: 10px; margin-top: 1px;"><%= act.target %></div>
          <div class="activity-time"><%= act.time %></div>
        </div>
      <% }); %>
    </div>
  </div>
</aside>
