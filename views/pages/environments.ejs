<%
  // activeEnv is provided by global res.locals
%>
<div style="display: flex; flex-direction: column; gap: 20px;">

  <!-- Page Header -->
  <div class="flex justify-between items-center flex-wrap gap-3">
    <div>
      <h1 style="font-size: 20px;">Multi-Environment Dashboard</h1>
      <p style="color: var(--text-muted); font-size: 12px; margin-top: 2px;">Deploy targets registry, configuration mapping, and version releases.</p>
    </div>
    <div>
      <span class="badge badge-success">US-EAST-1 + EU-WEST-1 clusters operational</span>
    </div>
  </div>

  <!-- Environments Cards Grid -->
  <div class="grid grid-cols-3 gap-6">
    <% environments.forEach(function(env) { %>
      <div class="card" style="<%= env.status === 'degraded' ? 'border-color: rgba(245, 158, 11, 0.4);' : '' %>">
        <div class="flex justify-between items-center mb-4">
          <div>
            <h3 style="font-size: 15px; color: var(--text-primary);"><%= env.name %></h3>
            <span style="font-family: var(--font-mono); font-size: 10px; color: var(--text-muted); text-transform: uppercase;"><%= env.slug %></span>
          </div>
          <span class="badge <%= env.status === 'operational' ? 'badge-success' : 'badge-warning' %>">
            <%= env.status %>
          </span>
        </div>

        <!-- Release metadata -->
        <div style="background-color: #0c0c0c; border: 1px solid var(--border); border-radius: 4px; padding: 12px; text-align: center; margin-bottom: 16px;">
          <div style="font-size: 10px; color: var(--text-muted); margin-bottom: 2px;">RELEASE VERSION</div>
          <strong class="text-mono" style="font-size: 16px; color: var(--text-primary);"><%= env.version %></strong>
        </div>

        <!-- Metric parameters -->
        <div class="grid grid-cols-2 gap-3" style="font-size: 12px; margin-bottom: 16px;">
          <div style="background-color: #0c0c0c; border: 1px solid var(--border); padding: 8px; border-radius: 4px;">
            <div style="font-size: 9px; color: var(--text-muted); text-transform: uppercase;">Uptime</div>
            <strong class="text-mono" style="color: var(--success); font-size: 11px;"><%= env.uptime %></strong>
          </div>
          <div style="background-color: #0c0c0c; border: 1px solid var(--border); padding: 8px; border-radius: 4px;">
            <div style="font-size: 9px; color: var(--text-muted); text-transform: uppercase;">Traffic</div>
            <strong class="text-mono" style="color: var(--text-primary); font-size: 11px;"><%= env.traffic %></strong>
          </div>
          <div style="background-color: #0c0c0c; border: 1px solid var(--border); padding: 8px; border-radius: 4px;">
            <div style="font-size: 9px; color: var(--text-muted); text-transform: uppercase;">Containers</div>
            <strong class="text-mono" style="color: var(--text-primary); font-size: 11px;"><%= env.containers %></strong>
          </div>
          <div style="background-color: #0c0c0c; border: 1px solid var(--border); padding: 8px; border-radius: 4px;">
            <div style="font-size: 9px; color: var(--text-muted); text-transform: uppercase;">Cluster Nodes</div>
            <strong class="text-mono" style="color: var(--text-primary); font-size: 11px;"><%= env.nodes %></strong>
          </div>
        </div>

        <!-- Release status footer -->
        <div style="border-top: 1px solid var(--border); padding-top: 12px; font-size: 11px; color: var(--text-muted);">
          <div>Last Deployment time:</div>
          <strong class="text-mono" style="color: var(--text-secondary); display: block; margin-top: 2px;"><%= env.lastDeployment %></strong>
          <div style="margin-top: 4px;">by <strong style="color: var(--text-secondary);"><%= env.deployedBy %></strong> (<%= env.lastDeploymentAgo %>)</div>
        </div>

        <!-- Switch target context -->
        <div style="margin-top: 12px; border-top: 1px solid var(--border); padding-top: 10px; text-align: right;">
          <button class="btn btn-sm <%= activeEnv === env.slug ? 'btn-primary' : 'btn-secondary' %>" style="width: 100%;" onclick="switchEnvironment('<%= env.slug %>')">
            <%= activeEnv === env.slug ? 'Active Environment' : 'Switch Target Context' %>
          </button>
        </div>
      </div>
    <% }); %>
  </div>

  <!-- Deployments by Environment -->
  <div class="card">
    <div class="card-header">
      <h2 class="card-title">Recent Activity by Target Environment</h2>
      <span class="card-subtitle">Release version synchronization history</span>
    </div>
    <div class="data-table-wrapper">
      <table class="data-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Version</th>
            <th>Target Environment</th>
            <th>Build Duration</th>
            <th>Triggered By</th>
            <th>Status</th>
            <th>Execution Date</th>
          </tr>
        </thead>
        <tbody>
          <% deployments.forEach(function(dep) { %>
            <tr>
              <td class="text-mono" style="font-size: 11px; color: var(--text-muted);"><%= dep.id %></td>
              <td class="text-mono" style="font-size: 12px; color: var(--text-primary); font-weight: 600;"><%= dep.version %></td>
              <td><span class="env-tag env-<%= dep.environment %>"><%= dep.environment %></span></td>
              <td class="text-mono" style="font-size: 11px;"><%= dep.duration %></td>
              <td><%= dep.deployedBy %></td>
              <td>
                <span class="badge <%= dep.status === 'success' ? 'badge-success' : dep.status === 'running' ? 'badge-info' : 'badge-error' %> btn-sm" style="font-size: 10px;">
                  <%= dep.status %>
                </span>
              </td>
              <td style="font-size: 11px; color: var(--text-muted);"><%= dep.timeAgo %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

</div>
